@model MvcCv.Models.Entity.TblDeneyimlerim

@{
    ViewBag.Title = "DeneyimGetir";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<br />
<h2>Deneyim Düzenleme sayfası</h2>
<br />

<form method="post">
    @Html.Label("Deneyim id")
    @Html.TextBoxFor(x => x.ID, new { @class = "form-control" })
    <br />
    @Html.Label("Başlığı giriniz")
    @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
    <br />
    @Html.Label("Alt Başlığı giriniz")
    @Html.TextBoxFor(x => x.AltBaslik, new { @class = "form-control" })
    <br />
    @Html.Label("Tarih giriniz")
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
    <br />
    @Html.Label("Açıklama giriniz")
    @Html.TextAreaFor(x => x.Aciklama , new { @class = "form-control" })
    <br />



    <button class="btn btn-info">Kaydet</button>



</form>


