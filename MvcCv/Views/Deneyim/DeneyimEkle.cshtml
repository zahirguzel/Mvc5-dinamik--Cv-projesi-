
@{
    ViewBag.Title = "DeneyimEkle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>Deneyim Ekleme sayfası</h2>
<br />

<form method="post">

    <input type="text" name="Baslik" class="form-control" placeholder="Başlık Giriniz" />
    <br />
    <input type="text" name="AltBaslik" class="form-control" placeholder="Alt Başlığı Giriniz" />
    <br />

    <input type="text" name="Tarih" class="form-control" placeholder="Tarih Giriniz" />
    <br />

    <textarea name="Aciklama" class="form-control" placeholder="Açıklama Giriniz" rows="5"></textarea>
    <br />


    <button class="btn btn-info">Kaydet</button>



</form>



